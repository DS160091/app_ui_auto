# 环境配置模板 — 复制为 .env 后填入你自己的值（.env 已被 .gitignore 忽略，不会提交）
#   cp .env.example .env

# ── 决策角色（Manager / App Opener / 结构化输出）：走强推理模型 ──
# 填你自己的模型服务凭证。默认示例走 Anthropic 官方端点，也可换成任意兼容网关。
DECISION_API_KEY="<your-api-key>"
DECISION_MODEL=claude-opus-4-8
DECISION_BASE_URL="https://api.anthropic.com"

# ── Executor 视觉定位角色：视觉模型 ──
EXECUTOR_PROVIDER=Anthropic
EXECUTOR_MODEL=claude-sonnet-4-6
EXECUTOR_API_KEY="<your-api-key>"
EXECUTOR_BASE_URL="https://api.anthropic.com"

# 若走自建/第三方兼容网关且要求 Bearer 鉴权（而非官方 x-api-key），置 1；用官方端点留空即可。
LLM_AUTH_BEARER=""

# ── 业务参数（示例流程用；接入自己的流程时按需增删）──
# 被测业务的测试用户 ID，仅示例 API skill 使用
TEST_UID="<your-test-uid>"
INTERVAL_MILLIS=3000

# ── 超时与重试 ──
POLL_TIMEOUT=15          # 编排层轮询后台任务的兜底超时（秒）
LLM_TIMEOUT=60           # 单次 LLM 请求超时（秒）
LLM_MAX_RETRIES=2        # LLM 请求重试上限

# ── ADB 设备连接 ──
# 手机与电脑是否同一 WiFi（必须是）；Android 是否 >= 11（是=无线调试 否=USB tcpip）
ADB_SAME_WIFI=是
ADB_ANDROID_11_PLUS=是
# 无线调试主界面的 IP:连接端口（日常重连只需这项）
ADB_CONNECT_INFO="<device-ip>:<connect-port>"
# 首次配对用：配对弹窗的 IP:配对端口 + 6 位配对码（配对码 1-2 分钟过期，被提示时再填）
ADB_PAIR_INFO="<device-ip>:<pair-port>"
ADB_PAIR_CODE="<pair-code>"

# ── 报告发布（可选，默认留空即只生成本地报告，不做任何外部上传）──
# 图片上传标识，仅在启用外部图床/报告平台时需要
PIC_UPLOAD_SIGN=""
